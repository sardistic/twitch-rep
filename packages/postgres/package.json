{
  "name": "@chatterscope/postgres",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "migrate": "tsx src/bin/migrate.ts",
    "seed": "tsx src/bin/seed.ts"
  },
  "dependencies": {
    "@chatterscope/config": "workspace:*",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@chatterscope/eslint-config": "workspace:*",
    "@chatterscope/typescript-config": "workspace:*",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "eslint": "^9.24.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
